    { "type": "text", "id": "title", "x": 360, "y": 20, "text": "Calibration Scope — How It Functions", "fontSize": 28, "fontFamily": 1, "strokeColor": "#1e1e1e", "originalText": "Calibration Scope — How It Functions", "autoResize": true },
