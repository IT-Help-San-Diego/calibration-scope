# Copy to .env and fill in your own values. Never commit the real .env file.
# The binary auto-loads ./.env from its WORKING DIRECTORY ONLY at startup (no
# parent-directory search). Variables already set in the environment always
# win — launchd/systemd values are never overridden by this file. Two
# consequences worth knowing:
#   - A service whose WorkingDirectory is a repo root will pick up a dev .env
#     there for any variable the service manager does NOT set. To opt a
#     service out of .env entirely, set CALIBRATION_SCOPE_NO_DOTENV=1 in it.
#   - API keys in .env re-enter the environment on every restart, so deleting
#     a key via the dashboard will not stick while .env still carries it.

# PostgreSQL connection for the model/test/run registry.
DATABASE_URL=postgres://YOUR_USER:YOUR_PASSWORD@localhost:5432/archetype_mesh

# Where the instrument's data files live (assets/, incl. pinned test stimuli).
# Unset = auto-resolve: alongside the executable, then ../share/calibration-scope,
# then the dev checkout. Prebuilt binaries also carry an embedded copy of
# assets/, so this only matters if you want disk overrides of embedded files.
#CALIBRATION_SCOPE_ROOT=

# HTTP bind address/port for the dashboard server.
LISTEN_ADDR=127.0.0.1
LISTEN_PORT=8768

# LM Studio's local REST server (Developer tab -> Local Server).
LMSTUDIO_BASE_URL=http://localhost:1234

# Optional — only needed if you want to benchmark cloud models.
# Leave unset and cloud runs will fail with a clear "no API key configured" error.
NOUS_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# Optional — Google AI Studio free tier (no credit card / prepay required).
# Supplies gemini-3.5-flash, a permanent-free multimodal model. Each deployer
# provides their OWN key; the server reads it from the environment only.
# macOS: inject via the launchd plist EnvironmentVariables.
# Linux:   inject via systemd EnvironmentFile or the service unit.
# Never commit a real key — keep it in your deployment env, not this repo.
GEMINI_API_KEY=
